# Copy to .env.local for local dev. For Vercel: Project → Settings → Environment Variables
# (same names and values as your Supabase project: Settings → API).
#
# Production: set NEXT_PUBLIC_SITE_URL to your real domain (e.g. https://credgenie.in) so
# sitemap.xml <loc>, robots.txt Sitemap:, and Open Graph metadataBase are never *.vercel.app.
# NEXT_PUBLIC_SITE_URL=https://credgenie.in
#
# Full path: local data/*.json → GCS (GCS_BUCKET + GCS_PREFIX) → Supabase (import_cards_from_gcs.py)
# → Vercel app reads Supabase only (set the three Supabase vars below; redeploy after changes).
# One command: npm run data:sync  (refreshes from data/*.docx if present, then upload + import)

# Required — hosted app reads credit_cards from this project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Strongly recommended for API routes (/api/cards, etc.) — server-side; never expose in client code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional — Python import scripts accept SUPABASE_URL if NEXT_PUBLIC_SUPABASE_URL is unset
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Optional catalog filter: Visa | Mastercard | Amex | unset | all | *
# NEXT_PUBLIC_CARD_NETWORK=

# Optional — AI features
# OPENAI_API_KEY=
# DISABLE_EXTERNAL_API_CALLS=

# Optional — Cuelinks (default channel / key 281873 if unset)
# Use the Channel ID from Account → My Channels; redeploy after changing NEXT_PUBLIC_* vars.
# “Check JavaScript installation” must use the exact site URL registered on that channel (www vs non-www).
# Site widget: cuelinks.js — set WIDGET_KEY if dashboard “key” differs from channel id
# NEXT_PUBLIC_CUELINKS_CHANNEL_ID=
# NEXT_PUBLIC_CUELINKS_WIDGET_KEY=
# Link Kit v2 (cdn0 cuelinksv2.js): set DISABLE_V2=true to turn off
# NEXT_PUBLIC_CUELINKS_DISABLE_V2=
# If v2 uses pub_id mode instead of cId:
# NEXT_PUBLIC_CUELINKS_PUB_ID=

# Optional — data pipeline (local / CI only, not required on Vercel for browsing cards)
# GCS_BUCKET=
# GCS_PREFIX=
